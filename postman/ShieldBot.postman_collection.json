  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": ["{{baseUrl}}"],
              "path": ["api", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('health ok', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const j = pm.response.json();",
                  "  pm.expect(j).to.have.property('status');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register (parent)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{parentEmail}}\",\n  \"password\": \"{{parentPassword}}\",\n  \"displayName\": \"{{parentDisplayName}}\",\n  \"role\": \"parent\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 409) {",
                  "  pm.test('already registered (ok)', () => pm.expect(pm.response.code).to.equal(409));",
                  "} else {",
                  "  pm.test('registered', () => pm.response.to.have.status(200));",
                  "  const j = pm.response.json();",
                  "  pm.environment.set('parentToken', j.token);",
                  "  pm.environment.set('parentUid', j.user.uid);",
                  "}"
                ]
              }
            }
          ]
