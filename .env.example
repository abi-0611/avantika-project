# Local PostgreSQL connection string for Drizzle/pg.
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/shieldbot"

# JWT config for custom auth (Phase 2+ will use these).
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Ollama config (Phase 3)
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1"
OLLAMA_VISION_MODEL="llava"
MEMORY_MAX_MESSAGES=20
