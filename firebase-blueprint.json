{
  "entities": {
    "Chat": {
      "title": "Chat Message",
      "description": "A single message in a conversation",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "text": { "type": "string", "description": "Message content" },
        "sender": { "type": "string", "enum": ["user", "bot"], "description": "Who sent the message" },
        "timestamp": { "type": "number", "description": "Unix timestamp" },
        "riskLevel": { "type": "string", "enum": ["Safe", "Low", "Moderate", "High"], "description": "Risk classification" },
        "riskCategory": { "type": "string", "description": "Category of risk detected" },
        "explanation": { "type": "string", "description": "Reason for risk classification" }
      },
      "required": ["uid", "text", "sender", "timestamp", "riskLevel"]
    },
    "SafetyLog": {
      "title": "Safety Event Log",
      "description": "A log of critical safety events",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "timestamp": { "type": "number", "description": "Unix timestamp" },
        "text": { "type": "string", "description": "The offending input" },
        "riskLevel": { "type": "string", "description": "Risk classification" },
        "riskCategory": { "type": "string", "description": "Category of risk" },
        "escalated": { "type": "boolean", "description": "Whether an emergency alert was triggered" }
      },
      "required": ["uid", "timestamp", "text", "riskLevel"]
    },
    "SafetyRule": {
      "title": "Safety Rule",
      "description": "Admin-defined safety keyword or rule",
      "type": "object",
      "properties": {
        "keyword": { "type": "string", "description": "Keyword to flag" },
        "category": { "type": "string", "description": "Risk category for this keyword" },
        "riskLevel": { "type": "string", "enum": ["Low", "Moderate", "High"], "description": "Risk level" }
      },
      "required": ["keyword", "category", "riskLevel"]
    },
    "Supervision": {
      "title": "Supervision Link",
      "description": "Links a guardian to a child account",
      "type": "object",
      "properties": {
        "guardianUid": { "type": "string", "description": "UID of the guardian" },
        "childUid": { "type": "string", "description": "UID of the child" },
        "childEmail": { "type": "string", "description": "Email of the child for linking" },
        "status": { "type": "string", "enum": ["pending", "active"], "description": "Link status" }
      },
      "required": ["guardianUid", "childUid", "status"]
    },
    "ChildSettings": {
      "title": "Child Safety Settings",
      "description": "Custom safety settings for a child account",
      "type": "object",
      "properties": {
        "childUid": { "type": "string", "description": "UID of the child" },
        "blockedKeywords": { "type": "array", "items": { "type": "string" }, "description": "Custom keywords to block" },
        "blockedTopics": { "type": "array", "items": { "type": "string" }, "description": "Topics to restrict" }
      },
      "required": ["childUid"]
    }
  },
  "firestore": {
    "chats": { "schema": "Chat", "description": "User chat messages" },
    "logs": { "schema": "SafetyLog", "description": "Critical safety event logs" },
    "rules": { "schema": "SafetyRule", "description": "Admin-defined safety rules" },
    "supervision": { "schema": "Supervision", "description": "Guardian-child links" },
    "childSettings": { "schema": "ChildSettings", "description": "Per-child safety overrides" }
  }
}
